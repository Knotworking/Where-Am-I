# Build and Generated files
# Exclude all build directories (recursive)
build/
**/build/
.gradle/
**/generated/

# IDE Configuration
# Most IDE settings are noise for code generation
.idea/
*.iml

# Sensitive Information
# NEVER let the AI see your local keys or secrets
local.properties
*.jks
*.keystore
google-services.json
mock-secrets.json

# Binaries and large assets
# These are noise for text-based context
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.webp
**/*.svg
**/*.mp4
**/*.wav
**/*.mp3
**/*.pdf

# Version Control internals
.git/

# OS Specific
.DS_Store
Thumbs.db

# Project Management
# Keep the plan internal to the agent's logic but out of general code context
plan.md
